# Supabase Configuration
# Local:  http://127.0.0.1:54321 (via `supabase start`)
# Hosted: https://<project-ref>.supabase.co (from dashboard → Settings → API)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=your-secret-key-here

# Storage Configuration
STORAGE_BUCKET=brand-assets

# Admin Configuration
ADMIN_EMAILS=admin@example.com

# Server Configuration (local dev only; Docker uses BACKEND_HOST/BACKEND_PORT)
HOST=127.0.0.1
PORT=8000
