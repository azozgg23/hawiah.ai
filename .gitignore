# ========================================
# Basar AI - .gitignore
# Next.js 14 + FastAPI + Supabase
# ========================================

# ----------------------------------------
# Environment & Secrets
# ----------------------------------------
.env
.env.*
!.env.example
!.env.local.example
.envrc

# ----------------------------------------
# Node.js / Next.js (Frontend)
# ----------------------------------------
node_modules/
.next/
out/
build/
dist/

# Next.js cache
.next/cache/

# Vercel
.vercel/

# NPM
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Package manager locks (keep one, ignore others if not used)
# Uncomment the ones you don't use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ----------------------------------------
# Python / FastAPI (Backend)
# ----------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
.venv/
env/
ENV/

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
sdist/
wheels/
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytest_cache/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# Pyright
pyrightconfig.json

# ----------------------------------------
# Supabase
# ----------------------------------------
supabase/.branches/
supabase/.temp/
.supabase/

# ----------------------------------------
# IDEs & Editors
# ----------------------------------------
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (PyCharm, WebStorm, IntelliJ)
.idea/
*.iml
*.ipr
*.iws

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# Sublime Text
*.sublime-workspace
*.sublime-project

# ----------------------------------------
# OS Files
# ----------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.lnk
desktop.ini

# Linux
*~

# ----------------------------------------
# Logs & Debugging
# ----------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ----------------------------------------
# Testing
# ----------------------------------------
coverage/
.nyc_output/
playwright-report/
playwright/.cache/
test-results/

# ----------------------------------------
# Build & Generated Files
# ----------------------------------------
*.local
*.tsbuildinfo
next-env.d.ts

# Storybook
storybook-static/

# ----------------------------------------
# Docker
# ----------------------------------------
docker-compose.override.yml

# ----------------------------------------
# Temporary Files
# ----------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak

# ----------------------------------------
# Misc
# ----------------------------------------
# Sentry
.sentryclirc

# Turbo
.turbo/

# PWA files
public/sw.js
public/workbox-*.js
public/worker-*.js

# TypeScript
*.tsbuildinfo

# ----------------------------------------
# Project Specific
# ----------------------------------------
# Uploaded assets (stored in Supabase, not git)
uploads/

# Local database dumps
*.sql.gz
*.dump

# API keys file (if accidentally created)
keys.json
secrets.json
credentials.json
.claude/settings.local.json
.opencode/
.agents/
.specs/
.specify